    uid=1_18 heading "AI-powered email for everyone" level="1"
    uid=1_19 StaticText "Secure, smart and easy-to-use email, used by billions, now enhanced with Gemini."
    uid=1_20 DisclosureTriangle "Create an account" expandable
    uid=1_21 link "Visit the Gmail product page" url="https://workspace.google.com/products/gmail/?from=gafb-gmail_asw-def-en"
      uid=1_22 StaticText "For work"
    uid=1_23 image "AI helping someone prepare for a presentation within Gmail, with search assistance, writing prompts, and suggested replies based on writing styles." url="https://lh3.googleusercontent.com/JUvH1rikZm12R8X_VilQFXEx7et5oiYKH1ZiirS9U67UytYokAARqTw5tz_wguIihqQhnRZQuZuP1G_YNXF0NzjAv48vzK6YzPZT=e365-pa-nu-rw-w528"
    uid=1_24 heading "Gemini in Gmail" level="2"
    uid=1_25 StaticText "With Gemini in Gmail, you get a personal, proactive inbox assistant that helps you respond quickly in your own voice, get things done faster, and turn information into answers without the digging."
    uid=1_26 DisclosureTriangle "Write better emails with the help of AI" expandable expanded
    uid=1_27 StaticText "Gemini in Gmail saves you time drafting or polishing emails and suggested replies help you reply in one click, in your voice."
    uid=1_28 image "Gmail suggesting an AI-generated reply to a pickleball class invitation, tailored to the user's writing style." url="https://lh3.googleusercontent.com/inapc0_DHeYpXzemlv53m-Y7Y_gfS118p9l7aSNlXuSQY6yLLbfTqjqMUZcKWPsjnLzQjPHwrenLkeCwpJiY6gOKhgJGtYSxhjc=e365-pa-nu-rw-w527"
    uid=1_29 DisclosureTriangle "Get caught up on email threads fast" expandable
    uid=1_30 DisclosureTriangle "Ask Gemini to search your inbox " expandable
    uid=1_31 heading "Email that’s secure, private, and puts you in control" level="2"
    uid=1_32 DisclosureTriangle "We never use your Gmail content for any ads purposes" expandable expanded
    uid=1_33 StaticText "Gmail uses industry-leading encryption for all messages you receive and send. We never use your Gmail content to personalize ads."
    uid=1_34 image "Privacy notification superimposed on an email" url="https://lh3.googleusercontent.com/f1FCowp2z17NBacYzg905JXHLqg1dyuxVMGhbkvBmwWOtcesAP5hC7b-yf_7rxgBB0gTzjCvEzd3g6DGX9-PTrwJoweFAMoSe9s=e365-pa-nu-rw-w527"
    uid=1_35 DisclosureTriangle "Gmail keeps over a billion people safe every day" expandable
    uid=1_36 DisclosureTriangle "The most advanced phishing protections available" expandable
    uid=1_37 DisclosureTriangle "Best-in-class controls over emails you send" expandable
    uid=1_38 heading "Get more done with Gmail" level="2"
    uid=1_39 DisclosureTriangle "Stay connected and get organized" expandable expanded
    uid=1_40 StaticText "Start a Chat, jump into a video call with Meet, or collaborate in a Doc, all right from Gmail."
    uid=1_41 image "Gmail chat function with document collaboration and video chat on one screen" url="https://lh3.googleusercontent.com/OJ4EfHYcL2U4vOUDwPYHdOWJIapcDvUsJpf6Pw6K4vJ-xaElcOopNNLqy5dc7a7rQZXU_jLXk_QqIBipqst2gpCIQT8EVhflIUfv7w=e365-pa-nu-rw-w527"
    uid=1_42 DisclosureTriangle "Get more done faster" expandable
    uid=1_43 DisclosureTriangle "Never forget to reply" expandable
    uid=1_44 heading "Gmail is better on the app" level="2"
    uid=1_45 DisclosureTriangle "Express yourself with emojis" expandable expanded
    uid=1_46 StaticText "Emoji reactions are a fast and fun way to reply to emails, only available with the Gmail app."
    uid=1_47 StaticText "A simplified phone UI displays an email welcoming Helen to the team, enlarged emoji bar indicates simplicity in replying with an emoji."
    uid=1_48 image "A simplified phone UI displays an email welcoming Helen to the team, enlarged emoji bar indicates simplicity in replying with an emoji."
    uid=1_49 DisclosureTriangle "Find your emails faster" expandable
    uid=1_50 DisclosureTriangle "Switch between accounts" expandable
    uid=1_51 heading "Bring the best of Gmail to your device" level="2"
    uid=1_52 link "Download Gmail on the App Store" url="https://apps.apple.com/us/app/gmail-email-by-google/id422689480"
    uid=1_53 link "Download Gmail on the Google Play Store" url="https://play.google.com/store/apps/details?id=com.google.android.gm&hl=en_US&gl=US"
    uid=1_54 image "Checkmark" url="https://storage.googleapis.com/gweb-workspace-assets/uploads/7uffzv9dk4sn-32gba2PjbUMYXtzXnESsih-931d9cf6159d22b675e5f607aa40acba-Icon.svg"
    uid=1_55 StaticText "Works with other tools"
    uid=1_56 StaticText "Gmail works great with desktop clients like Microsoft Outlook, Apple Mail and Mozilla Thunderbird, including contact and event sync."
    uid=1_57 image "Offline icon" url="https://storage.googleapis.com/gweb-workspace-assets/uploads/7uffzv9dk4sn-7ev7sVBRefeLyFw3FKLX0C-5d5caaf4db50da492ee9cc482b47ac9c-AI_for_HR_TemplateMulticolumn_Icon_Effective_performance_management.svg"
    uid=1_58 StaticText "Stay productive, even offline"
    uid=1_59 StaticText "Gmail offline lets you read, reply, delete, and search your Gmail messages when you’re not connected to the internet."
    uid=1_60 image "Laptop, smart watch and mobile devices" url="https://storage.googleapis.com/gweb-workspace-assets/uploads/7uffzv9dk4sn-2zCPv3JQx1zhM6vY5sqHFS-8a2560093e4105f5db389f59703026d4-AI_for_HR_TemplateMulticolumn_Icon_Faster_decision_making_at_scale.svg"
    uid=1_61 StaticText "Experience Gmail on any device"
    uid=1_62 StaticText "Enjoy the ease and simplicity of Gmail, wherever you are."
    uid=1_63 image "A row of icons displaying Google Workspace products." url="https://storage.googleapis.com/gweb-workspace-assets/uploads/7uffzv9dk4sn-12u8F33yMpGrJ47b1JYGhI-736f5142ccb97caf0bd51159e678952c-Google_Workspace_Product_5-Icon_Lockup.svg"
    uid=1_64 heading "Gmail is now part of Google Workspace" level="2"
    uid=1_65 StaticText "Collaborate faster, from any device, anytime, all in one place."
    uid=1_66 StaticText "Google Workspace is a set of productivity and collaboration tools that helps individuals, teams, and businesses stay on top of everything. It is a flexible, innovative solution for "
    uid=1_67 link "Open the business page" url="https://workspace.google.com/solutions/business-email/"
      uid=1_68 StaticText "business"
    uid=1_69 StaticText " or personal use that includes all of your favorite apps like Gmail, Calendar, Drive, Docs, Meet, and more."
    uid=1_70 link "Visit the Google Workspace website" url="https://workspace.google.com/"
      uid=1_71 StaticText "Learn more"
    uid=1_72 heading "Find the answers you need" level="2"
    uid=1_73 button "Expand all"
    uid=1_74 DisclosureTriangle "How does Gmail keep my email communications secure and private?" expandable expanded
    uid=1_75 StaticText "Gmail has always had strong security as a foundation. We work hard to protect you from spam, phishing, and malware, before they reach your inbox. Our AI-enhanced spam-filtering capabilities block nearly 10 million spam emails every minute."
    uid=1_76 DisclosureTriangle "Do you use my email for ads?" expandable
    uid=1_77 DisclosureTriangle "How can I keep my emails even more safe and secure?" expandable
    uid=1_78 DisclosureTriangle "What if I want to use Gmail for work or my business?" expandable
    uid=1_79 heading "Need more help?" level="3"
    uid=1_80 StaticText "Browse tips and step-by-step guides made for both new users and power users."
    uid=1_81 link "Visit the Gmail help center" url="https://support.google.com/mail/?hl=en#topic=7065107"
      uid=1_82 StaticText "Help Center"
