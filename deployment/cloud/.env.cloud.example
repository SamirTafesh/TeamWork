# Copy to deployment/cloud/.env.cloud and fill values before deploy.

# Public domains
# APP + API are required.
# WORKERS is optional and only used when PROVISIONER_MODE=daytona.
APP_DOMAIN=teamwork.aitech-services.com
API_DOMAIN=api-teamwork.aitech-services.com
WORKERS_DOMAIN=workers.aitech-services.com

APP_PUBLIC_URL=https://teamwork.aitech-services.com
API_PUBLIC_URL=https://api-teamwork.aitech-services.com
WORKER_PROXY_PUBLIC_URL=https://workers.aitech-services.com

# Local bind ports on the VM (reverse-proxied by Nginx)
DEN_WEB_PORT=3005
DEN_API_PORT=8788
DEN_WORKER_PROXY_PORT=8789

# MySQL
MYSQL_DATABASE=teamwork_den
MYSQL_ROOT_PASSWORD=replace-with-strong-password

# Den API auth + crypto (required)
BETTER_AUTH_SECRET=replace-with-64-plus-char-secret
DEN_DB_ENCRYPTION_KEY=replace-with-64-plus-char-secret

# Enable dev behavior in production only if you explicitly want test-mode email behavior.
TEAMWORK_DEV_MODE=0

# Worker provisioner mode: stub | daytona | render
# Defaulting to stub means no real cloud worker provisioning.
PROVISIONER_MODE=stub

# Optional in stub mode (used for placeholder worker URL in dashboard data).
WORKER_URL_TEMPLATE=https://workers.local/{workerId}

# Daytona (only required when PROVISIONER_MODE=daytona)
DAYTONA_API_URL=https://app.daytona.io/api
DAYTONA_API_KEY=
DAYTONA_TARGET=
DAYTONA_SNAPSHOT=
DAYTONA_WORKER_PROXY_BASE_URL=https://workers.aitech-services.com
DAYTONA_SIGNED_PREVIEW_EXPIRES_SECONDS=86400

# Optional OAuth providers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email delivery (required for email/password verification in non-dev mode).
# Preferred option: SMTP.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="TeamWork <no-reply@aitech-services.com>"
SMTP_REPLY_TO=

# Optional Loops fallback (used only when SMTP is not configured).
LOOPS_API_KEY=
LOOPS_TRANSACTIONAL_ID_DEN_VERIFY_EMAIL=
LOOPS_TRANSACTIONAL_ID_DEN_ORG_INVITE_EMAIL=

# Optional CORS override (comma-separated)
CORS_ORIGINS=https://teamwork.aitech-services.com
DEN_BETTER_AUTH_TRUSTED_ORIGINS=https://teamwork.aitech-services.com

# Optional PostHog client settings for den-web
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=
