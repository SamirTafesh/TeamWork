{
  "name": "@SamirTafesh/TeamWork-workspace",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "TEAMWORK_DEV_MODE=1 pnpm --filter @teamwork/desktop dev",
    "dev:electron": "TEAMWORK_DEV_MODE=1 pnpm --filter @teamwork/desktop dev:electron",
    "dev:server-v2": "node scripts/dev-server-v2.mjs",
    "dev:server-v2:server": "node scripts/dev-server-v2.mjs --no-app",
    "dev:windows": ".\\scripts\\dev-windows.cmd",
    "dev:windows:x64": ".\\scripts\\dev-windows.cmd x64",
    "dev:ui": "TEAMWORK_DEV_MODE=1 pnpm --filter @teamwork/app dev",
    "dev:ui-demo": "pnpm --filter @teamwork/ui-demo dev",
    "dev:story": "TEAMWORK_DEV_MODE=1 pnpm --filter @teamwork/story-book dev",
    "dev:web": "pnpm run dev:den:web",
    "dev:den": "node scripts/dev-local.mjs",
    "dev:den-local": "pnpm run dev:den",
    "dev:den:mysql": "docker compose -p teamwork-den-local -f packaging/docker/docker-compose.web-local.yml up -d --wait mysql",
    "dev:den:mysql:down": "docker compose -p teamwork-den-local -f packaging/docker/docker-compose.web-local.yml down",
    "dev:den:db-push": "sh -lc 'DATABASE_URL=${DATABASE_URL:-mysql://root:password@127.0.0.1:3306/teamwork_den} DEN_DB_ENCRYPTION_KEY=${DEN_DB_ENCRYPTION_KEY:-local-dev-db-encryption-key-please-change-1234567890} pnpm --filter @teamwork-ee/den-db db:push'",
    "dev:den:api": "sh -lc 'DEN_WEB_PORT=${DEN_WEB_PORT:-3005}; TEAMWORK_APP_PORT=${TEAMWORK_APP_PORT:-5173}; DEN_LOCAL_ORIGINS=http://localhost:$DEN_WEB_PORT,http://127.0.0.1:$DEN_WEB_PORT,http://localhost:$TEAMWORK_APP_PORT,http://127.0.0.1:$TEAMWORK_APP_PORT; TEAMWORK_DEV_MODE=1 PORT=${DEN_API_PORT:-8790} DATABASE_URL=${DATABASE_URL:-mysql://root:password@127.0.0.1:3306/teamwork_den} DEN_DB_ENCRYPTION_KEY=${DEN_DB_ENCRYPTION_KEY:-local-dev-db-encryption-key-please-change-1234567890} BETTER_AUTH_SECRET=${BETTER_AUTH_SECRET:-local-dev-secret-not-for-production-use!!} BETTER_AUTH_URL=${BETTER_AUTH_URL:-http://localhost:$DEN_WEB_PORT} DEN_BETTER_AUTH_TRUSTED_ORIGINS=${DEN_BETTER_AUTH_TRUSTED_ORIGINS:-$DEN_LOCAL_ORIGINS} CORS_ORIGINS=${CORS_ORIGINS:-$DEN_LOCAL_ORIGINS} PROVISIONER_MODE=${PROVISIONER_MODE:-stub} pnpm --filter @teamwork-ee/den-api dev:local'",
    "dev:den:web": "sh -lc 'DEN_API_PORT=${DEN_API_PORT:-8790}; DEN_WEB_PORT=${DEN_WEB_PORT:-3005}; TEAMWORK_DEV_MODE=1 NEXT_PUBLIC_POSTHOG_KEY= NEXT_PUBLIC_POSTHOG_API_KEY= DEN_API_BASE=${DEN_API_BASE:-http://localhost:$DEN_API_PORT} DEN_AUTH_ORIGIN=${DEN_AUTH_ORIGIN:-http://localhost:$DEN_WEB_PORT} DEN_AUTH_FALLBACK_BASE=${DEN_AUTH_FALLBACK_BASE:-http://localhost:$DEN_API_PORT} pnpm --filter @teamwork-ee/den-web dev:local'",
    "dev:den-docker": "bash packaging/docker/den-dev-up.sh",
    "dev:den:seed-demo": "pnpm --filter @teamwork-ee/den-api seed:demo-org",
    "dev:headless-web": "TEAMWORK_DEV_MODE=1 bun scripts/dev-headless-web.ts",
    "build": "node scripts/build.mjs",
    "build:ui": "pnpm --filter @teamwork/app build",
    "build:web": "pnpm --filter @teamwork-ee/den-web build",
    "preview": "pnpm --filter @teamwork/app preview",
    "sdk:generate": "pnpm --filter teamwork-server-v2 openapi:generate && pnpm --filter @teamwork/server-sdk generate",
    "sdk:watch": "pnpm --filter @teamwork/server-sdk watch",
    "contract:check": "node scripts/check-server-v2-contract.mjs",
    "typecheck": "pnpm run sdk:generate && pnpm --filter @teamwork/app typecheck",
    "test:health": "pnpm --filter @teamwork/app test:health",
    "test:sessions": "pnpm --filter @teamwork/app test:sessions",
    "test:refactor": "pnpm --filter @teamwork/app test:refactor",
    "test:events": "pnpm --filter @teamwork/app test:events",
    "test:todos": "pnpm --filter @teamwork/app test:todos",
    "test:permissions": "pnpm --filter @teamwork/app test:permissions",
    "test:session-error-recovery": "pnpm --filter @teamwork/app test:session-error-recovery",
    "test:session-scope": "pnpm --filter @teamwork/app test:session-scope",
    "test:session-switch": "pnpm --filter @teamwork/app test:session-switch",
    "test:fs-engine": "pnpm --filter @teamwork/app test:fs-engine",
    "test:e2e": "pnpm --filter @teamwork/app test:e2e",
    "test:orchestrator": "pnpm --filter teamwork-orchestrator test:router",
    "bump:patch": "pnpm --filter @teamwork/app bump:patch",
    "bump:minor": "pnpm --filter @teamwork/app bump:minor",
    "bump:major": "pnpm --filter @teamwork/app bump:major",
    "bump:set": "pnpm --filter @teamwork/app bump:set",
    "release:review": "node scripts/release/review.mjs",
    "release:prepare": "node scripts/release/prepare.mjs",
    "release:prepare:dry": "node scripts/release/prepare.mjs --dry-run",
    "release:ship": "node scripts/release/ship.mjs",
    "release:ship:watch": "node scripts/release/ship.mjs --watch"
  },
  "devDependencies": {
    "turbo": "^2.5.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@whiskeysockets/baileys",
      "better-sqlite3",
      "electron",
      "esbuild",
      "protobufjs"
    ],
    "patchedDependencies": {
      "@solidjs/router@0.15.4": "patches/@solidjs__router@0.15.4.patch"
    }
  },
  "packageManager": "pnpm@10.27.0"
}
